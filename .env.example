# BrightChamps Design System — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env.

# Figma REST API — https://www.figma.com/developers/api#access-tokens
# Required for: npm run extract:figma, npm run publish:figma
FIGMA_ACCESS_TOKEN=

# Anthropic API — https://console.anthropic.com/settings/keys
# Required for: npm run ledger:build (resolver uses Claude for conflict flagging)
ANTHROPIC_API_KEY=

# Playwright auth cookies (per-surface session cookies for protected pages)
# Required for: npm run extract:dom on student/teacher/admin surfaces
STUDENT_COOKIE=
TEACHER_COOKIE=
ADMIN_COOKIE=

# Optional: run Playwright with visible browser for debugging
# PLAYWRIGHT_HEADED=true
